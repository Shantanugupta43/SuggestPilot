{
  "name": "ai-context-assistant",
  "version": "1.0.0",
  "description": "Intelligent browser extension that provides context-aware suggestions using AI",
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "validate": "npm run lint && npm test"
  },
  "keywords": [
    "browser-extension",
    "ai",
    "openai",
    "productivity",
    "context-aware"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ai-context-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/ai-context-assistant/issues"
  },
  "homepage": "https://github.com/yourusername/ai-context-assistant#readme",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@jest/globals": "^30.3.0",
    "babel-jest": "^30.3.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.2.5"
  }
}
