# SuggestPilot — Configurable Values Reference
#
# This extension stores all configuration in chrome.storage.local at runtime.
# This file documents every configurable value for development and reference purposes.
# To change these values, use the extension popup Settings panel or edit src/utils/constants.js.

# ── API Configuration ────────────────────────────────────────────────────────

# Groq API Key — must start with "gsk_" and be at least 10 characters
# Get yours at https://console.groq.com/keys
# Format: gsk_<random alphanumeric string>
GROQ_API_KEY=gsk_your_api_key_here

# AI Model — choose from available Groq models
# Valid values:
#   llama-3.1-8b-instant      (fastest, default)
#   llama-3.3-70b-versatile   (higher quality, slower)
#   llama-3.1-70b-versatile   (balanced)
#   gemma2-9b-it              (alternative model)
GROQ_MODEL=llama-3.1-8b-instant

# Max tokens per API request (integer, 1–4096)
# Controls how long the AI response can be. Higher = more detail but more latency.
MAX_TOKENS=200

# Temperature for AI generation (float, 0.0–1.0)
# 0.0 = deterministic, 1.0 = creative/random
TEMPERATURE=0.4

# Top-p sampling (float, 0.0–1.0)
# Controls diversity of token selection
TOP_P=0.9

# ── Timing ───────────────────────────────────────────────────────────────────

# Debounce delay for regular input fields (ms, 100–2000)
# How long to wait after the user stops typing before generating suggestions
DEBOUNCE_MS=500

# Debounce delay for address bar / search input (ms, 100–2000)
# Shorter debounce for search bars since users type faster there
ADDRESS_BAR_DEBOUNCE_MS=400

# Session TTL — how long until a research session expires (ms)
# 30 minutes = 1800000, 2 hours = 7200000
# After this period of inactivity, the session summary is cleared
SESSION_TTL_MS=1800000

# Summary rebuild interval — how many new queries trigger a session summary rebuild (integer, 1–10)
SUMMARY_REBUILD_INTERVAL=5

# Loading timeout — max time to show "Thinking…" before auto-dismiss (ms)
LOADING_TIMEOUT=15000

# ── Limits ───────────────────────────────────────────────────────────────────

# Max suggestions returned per request (integer, 1–5)
MAX_SUGGESTIONS=3

# Max queries tracked in the session rolling window (integer, 5–50)
MAX_QUERIES=20

# Max past searches stored in chrome.storage.local (integer, 10–200)
MAX_PAST_SEARCHES=50

# Max open tabs included in the context prompt (integer, 1–10)
MAX_ACTIVE_TABS=5

# Max browsing history results fetched (integer, 5–50)
MAX_HISTORY_RESULTS=15

# Max top-visited sites included in context (integer, 1–10)
MAX_TOP_VISITED=5

# Max recent AI chat tabs included in context (integer, 1–5)
MAX_AI_TABS=3

# ── Suggestion Validation ────────────────────────────────────────────────────

# Minimum suggestion text length (characters)
MIN_SUGGESTION_LENGTH=3

# Maximum suggestion text length (characters)
MAX_SUGGESTION_LENGTH=200

# ── UI ───────────────────────────────────────────────────────────────────────

# Min characters typed before suggestions trigger (integer, 1–5)
SUGGESTION_MIN_INPUT_LENGTH=1

# Delay after focus-out before hiding overlay (ms)
SUGGESTION_FOCUSOUT_DELAY=200

# How long status messages stay visible in popup (ms)
STATUS_MESSAGE_TIMEOUT=5000

# ── Blocked Domains ──────────────────────────────────────────────────────────

# Domains where the extension stays completely silent (newline-separated)
# Suggestions won't appear on these sites. Edit via popup Settings panel.
#
# Banking: chase.com, bankofamerica.com, wellsfargo.com, citibank.com
# Healthcare: mychart.com, kp.org, cerner.com
# Government: ssa.gov, irs.gov, uscis.gov, va.gov
# Password managers: lastpass.com, 1password.com, dashlane.com, bitwarden.com
# Social: linkedin.com
BLOCKED_DOMAINS=linkedin.com
chase.com
bankofamerica.com
wellsfargo.com
mychart.com
kp.org
ssa.gov
irs.gov
lastpass.com
1password.com
